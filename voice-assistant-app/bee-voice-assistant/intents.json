  "slots": {
    "order_id": {
      "method": "regex",
      "pattern": "ORD-\\d{6,}"
    },
    "sku": {
      "method": "regex",
      "pattern": "LK-[A-Z0-9]{4,}"
    },
    "color": {
      "method": "value_list",
      "values": [
        "black",
        "matte_black",
        "gold",
        "silver",
        "blue",
        "red",
        "brown"
      ]
    },
    "frame_type": {
      "method": "value_list",
      "values": [
        "aviator",
        "round",
        "wayfarer",
        "cat_eye",
        "rectangle",
        "square"
      ]
    },
    "city": {
      "method": "value_list",
      "values": [
        "mumbai",
        "delhi",
        "bangalore",
        "pune",
        "chennai",
        "hyderabad"
      ]
    },
    "lens_type": {
      "method": "value_list",
      "values": [
        "blue_light",
        "progressive",
        "bifocal",
        "single_vision"
      ]
    },
    "price_range": {
      "method": "regex",
      "pattern": "(?:under|below) (\\d+)"
    }
  }
